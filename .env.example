# Copy to .env and fill in. Used by backend; frontend may have its own .env.local.

# Database (matches docker-compose)
DATABASE_URL=postgresql://roborebut:roborebut_dev@localhost:5432/roborebut

# Redis
REDIS_URL=redis://localhost:6379

# Clerk (backend JWT verification)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# OpenAI
OPENAI_API_KEY=

# Deepgram (streaming STT)
DEEPGRAM_API_KEY=

# Twilio (real calls; optional for local mock mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=

# Server
BACKEND_PORT=3001
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
