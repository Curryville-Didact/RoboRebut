{
  "name": "@roborebut/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "live:validate": "tsx src/engine/liveRegressionValidation.ts",
    "intelligence:rebuild": "tsx src/tools/intelligenceRebuild.ts",
    "test:intelligence": "npm run build --silent && node dist/services/intelligence/offlineIntelligence.test.js && node dist/services/intelligence/variantInventoryRegistry.test.js && node dist/services/intelligence/intelligenceSummary.test.js && node dist/lib/hardening.test.js && node dist/services/integrations/outboundDispatcher.test.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/websocket": "^11.0.1",
    "@prisma/client": "^6.0.0",
    "@supabase/supabase-js": "^2.99.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
