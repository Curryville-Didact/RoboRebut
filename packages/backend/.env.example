# Prisma: local dev default. To use hosted Postgres (same instance as Supabase), set URI from
# Supabase → Settings → Database (must match SUPABASE_URL project ref). Analytics (eventTracker)
# always uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY, not DATABASE_URL.
DATABASE_URL=postgresql://roborebut:roborebut_dev@localhost:5432/roborebut
REDIS_URL=redis://localhost:6379
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
OPENAI_API_KEY=
# Default coach model (live + Deep precall): COACH_LIVE_MODEL → OPENAI_CHAT_MODEL → gpt-4o-mini
# COACH_LIVE_MODEL=gpt-4o
# OPENAI_CHAT_MODEL=gpt-4o
# Pre-call Instant only: fast completion (env or default gpt-4o-mini); must differ from Deep for real speed split
# COACH_PRECALL_INSTANT_MODEL=gpt-4o-mini
DEEPGRAM_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
BACKEND_PORT=3001
PORT=3001
NODE_ENV=development
# DEV ONLY: set to "true" to skip free-tier usage cap for local testing (coach + deal insight path)
BYPASS_USAGE_LIMITS=false
# Also used for Polar checkout success/return URL base when Referer is missing.
FRONTEND_URL=http://localhost:3000

# Founder Support Console (GET /api/founder/support/account): comma-separated emails that may call the
# endpoint after normal Bearer auth. Case-insensitive. Falls back to admin@getrebut.ai if unset.
# FOUNDER_EMAILS=founder@example.com,other@example.com
# Comma-separated list of allowed browser Origins (CORS + WebSocket). Overrides default list.
# CORS_ORIGINS=http://localhost:3003,http://127.0.0.1:3003

# OpenClaw Gateway (for Claude rebuttal generation via Phase 2.2)
# Get token from: cat ~/.openclaw/openclaw.json | grep token
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
CLAUDE_MODEL=anthropic/claude-sonnet-4-6

# Supabase (Phase 3.0)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Polar entitlement sync (Phase 5.4)
# Organization Access Token from Polar dashboard — must include scopes used below:
#   checkouts:write (required for POST /v1/checkouts/ redirect checkout)
#   customer_sessions:write (required for POST /v1/customer-sessions/ — Starter→Pro portal upgrade)
#   plus whatever your entitlement sync lists need (e.g. customers read, subscriptions read).
POLAR_ACCESS_TOKEN=
# Same API host as your token (production default). Use https://sandbox-api.polar.sh/v1 for sandbox tokens.
# POLAR_API_BASE=https://api.polar.sh/v1
# Optional but recommended for exact product matching; otherwise falls back to product name.
POLAR_ORGANIZATION_ID=
# Product IDs from Polar → Products → copy Product ID (UUID). Used by GET /api/billing/checkout/redirect to create checkout sessions with success_url/return_url (not the old static buy.polar.sh link IDs).
POLAR_STARTER_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=
