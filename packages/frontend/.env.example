NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
# Dashboard/API calls fail with connection refused if backend is not running — from repo root: npm run dev -w packages/backend (default port 3001).
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
# Optional override; default is derived from NEXT_PUBLIC_API_URL + /ws
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:3001/ws

# Supabase (Phase 3.0)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dev-only: set to 1 to skip root `/` Supabase getUser() and redirect to /dashboard (unstick localhost if auth hangs).
# ROBREBUT_SKIP_ROOT_AUTH=1
